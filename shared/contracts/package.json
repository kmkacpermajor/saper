{
  "name": "@saper/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "protoc --proto_path proto --ts_out src/generated proto/game.proto && tsc -p tsconfig.json",
    "check:generated": "pnpm run generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@protobuf-ts/runtime": "^2.11.1"
  },
  "devDependencies": {
    "@protobuf-ts/plugin": "^2.11.1",
    "@protobuf-ts/protoc": "^2.11.1",
    "typescript": "^5.8.2"
  }
}